demuxer-cache-unselected-audio=yes
demuxer-cache-unselected-subs=yes

# New upstream mpv feature: a builtin context menu is now force-bound to
# right-click by default (context_menu.lua, DOCS/man/context_menu.rst). On
# platforms without native-menu integration (Linux/X11/Wayland; Windows has
# its own native integration but this keeps behavior consistent) it stays on
# unless disabled here. Restores right-click = play/pause via input.conf.
load-context-menu=no

# ── Windows additions (migrated from the Linux launcher mpv_patched.sh; mpv
#    auto-uses the portable_config dir beside mpv.exe, so no wrapper needed) ──
input-ipc-server=\\.\pipe\mpv-socket
gpu-shader-cache-dir=~~/shader_cache
icc-cache-dir=~~/icc_cache
# Windows has no OpenSSL CA store — ship Mozilla's bundle for HTTPS
# certificate verification (applies to normal streams AND the segmented
# downloader via mp_setup_av_network_options).
tls-ca-file=~~/cacert.pem
tls-verify=yes

ao=wasapi                                    # WASAPI audio output (Windows)
audio-channels=7.1,5.1,stereo
# Pick YOUR audio output device, then uncomment. To find its mpv name:
#   mpv --audio-device=help            # lists every device, e.g. 'wasapi/{0a1b2c3d-...}'
# audio-exclusive=yes (below) opens the device in WASAPI exclusive mode — that is
# what allows untouched spdif/TrueHD-MAT bitstream passthrough to the receiver.
# Leave commented to use the system default output.
#audio-device='wasapi/{xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}'
audio-exclusive=yes
audio-spdif=ac3,dts,eac3,dts-hd,truehd
audio-buffer=0.5

demuxer-max-bytes=1GiB
demuxer-max-back-bytes=8GiB


vo=gpu-next
hdr-compute-peak=yes
tone-mapping=bt.2446a
tone-mapping-param=0.58
target-peak=1100
gamut-mapping-mode=saturation
gpu-api=vulkan
vd-lavc-threads=16
video-sync=display-vdrop

# Key watch_later resume on the filename only, NOT the full path. This also
# disables mpv's write_redirects_for_parent_dirs(), so playing a local file no
# longer litters watch_later/ with a "# redirect entry" for every ancestor dir
# (/home, /home/you, /home/you/Media, …). Per-file resume still works.
# NOTE: must live here in the GLOBAL section — the [s95b-anticrush] profile
# (line 53) swallows everything down to line ~351, and it is only applied
# conditionally by auto-profiles.lua, so options placed there are unreliable.
ignore-path-in-watch-later-config=yes


sub-visibility=yes
screen=1
cursor-autohide=200
ontop
osc=no
reset-on-next-file=audio-delay,mute,pause,speed,sub-delay,video-aspect-override,video-pan-x,video-pan-y,video-rotate,video-zoom,force-media-title
save-position-on-quit=yes
script-opts-append=linux.or.windows-memory_usage_percentage=10
script-opts-append=autocrop-auto_delay=0
script-opts-append=autocrop-auto=no
script-opts-append=autocrop-detect_seconds=3
script-opts-append=osc-scalefullscreen=1.5
script-opts-append=osc-scalewindowed=1.0
script-opts-append=osc-vidscale=no   # Do not scale by window size
term-osd-bar=yes
term-playing-msg=yes
volume-max=100
volume=100
watch-later-options-remove=ab-loop-b
watch-later-options-remove=ab-loop-a
watch-later-options-remove=af
watch-later-options-remove=aid
watch-later-options-remove=audio-delay
watch-later-options-remove=border
watch-later-options-remove=brightness
watch-later-options-remove=contrast
watch-later-options-remove=deinterlace
watch-later-options-remove=fullscreen
watch-later-options-remove=gamma
watch-later-options-remove=mute
watch-later-options-remove=ontop
watch-later-options-remove=osd-level
watch-later-options-remove=panscan
watch-later-options-remove=pause
watch-later-options-remove=saturation
watch-later-options-remove=sid
watch-later-options-remove=speed
watch-later-options-remove=sub-ass-override
watch-later-options-remove=sub-delay
watch-later-options-remove=sub-pos
watch-later-options-remove=sub-scale
watch-later-options-remove=sub-visibility
#watch-later-options-remove=start
#watch-later-options-remove=vf
#watch-later-options-remove=volume
watch-later-options-remove=vid
watch-later-options-remove=video-aspect-override
watch-later-options-remove=video-zoom
watch-later-options-remove=video-align-x
watch-later-options-remove=video-align-y
write-filename-in-watch-later-config=yes
osd-playing-msg-duration=3000

# Renderer #
vo=gpu-next
target-colorspace-hint=yes
profile=gpu-hq
gpu-api=vulkan

# GENERAL #
#fs=yes                             #start in fullscreen     
ytdl=yes                            
keep-open=no
autofit=65%
geometry=50%:50%                    #start with window in the middle
autofit-larger=40%x50%
watch-later-directory="~~/watch_later/"  #default directory for save-position-on-quit
hr-seek-framedrop=no
border=no
msg-color=yes
msg-module=yes

# Screenshots #                    
screenshot-template="%x\Screens\Screenshot-%F-T%wH.%wM.%wS.%wT-F%{estimated-frame-number}"
screenshot-format=png               # Set screenshot format
screenshot-png-compression=4        # Range is 0 to 10. 0 being no compression. compute-time to size is log so 4 is best
screenshot-tag-colorspace=yes
screenshot-high-bit-depth=yes       # Same output bitdepth as the video

# OSC/OSD #

osc=yes
osd-bar=yes                          # Do not remove/comment if mpv_thumbnail_script_client_osc.lua is being used.
osd-font='Inter Tight Medium'        # Set a font for OSC
osd-font-size=30                     # Set a font size
osd-color='#CCFFFFFF'                # ARGB format
osd-border-color='#DD322640'         # ARGB format
osd-bar-align-y=-1                   # progress bar y alignment (-1 top, 0 centered, 1 bottom)
osd-border-size=2                    # size for osd text and progress bar
osd-bar-h=1                          # height of osd bar as a fractional percentage of your screen height
osd-bar-w=60                         # width of " " "

# Subs #

#blend-subtitles=no                  # <yes|video|no>
sub-ass-use-video-data=all           # Backward compatibility for vsfilter fansubs
sub-ass-scale-with-window=no         # May have undesired effects with signs being misplaced.
sub-fix-timing=yes 
sub-auto=fuzzy                       # external subs don't have to match the file name exactly to autoload
#sub-gauss=0.6                       # Some settings fixing VOB/PGS subtitles (creating blur & changing yellow subs to gray)
sub-file-paths-append=ass            # search for external subs in these relative subdirectories
sub-file-paths-append=srt
sub-file-paths-append=sub
sub-file-paths-append=subs
sub-file-paths-append=subtitles
demuxer-mkv-subtitle-preroll=yes     # try to correctly show embedded subs when seeking
embeddedfonts=yes                    # use embedded fonts for SSA/ASS subs
sub-fix-timing=no                    # do not try to fix gaps (which might make it worse in some cases). Enable if there are scenebleeds.
sub-pos=102

# Subs - Forced # 

sub-font=Open Sans SemiBold
sub-font-size=46
sub-blur=0.3
sub-border-color=0.0/0.0/0.0/0.8
sub-border-size=3.2
sub-color=0.9/0.9/0.9/1.0
#sub-margin-x=100
#sub-margin-y=50
sub-shadow-color=0.0/0.0/0.0/0.25
sub-shadow-offset=0
sub-pos=102

# Languages #

alang=eng,en,enUS,en-US,jpn,jp,de,ger
slang=eng,en,und,de,ger,jp,jap 

# Video Profiles #

dither=ordered
dither-depth=12
scale=ewa_lanczos
cscale=lanczos
dscale=mitchell
scale-antiring=0
cscale-antiring=0
correct-downscaling=yes
linear-downscaling=no
sigmoid-upscaling=yes

# Debanding #

deband=yes
deband-iterations=2
deband-threshold=40                  #increase this number to increase deband strenght but lose some detail
deband-range=16
deband-grain=48
dither-depth=auto

# interpolation #

interpolation=no                     #can be toggled with key i
video-sync=display-resample
tscale=oversample

blend-subtitles=no


profile=sub-profile-unobtrusive

[sub-profile-unobtrusive]
 sub-ass-override=yes
 sub-font="Helvetica"
 sub-font-size=30
 sub-color=.75/.85
 sub-border-color=0/.33
 sub-shadow-color=0/.33
 sub-shadow-offset=.75
 sub-pos=102
 sub-border-size=1
 #slang=spa
 #sub-margin-x=10
 #sub-margin-y=10

 #no-border

[sub-profile-prominent]
 sub-ass-override=yes
 sub-font="Helvetica"
 sub-font-size=30
 sub-color=.95/.95
 sub-border-color=.15/.93
 sub-shadow-color=0/.33
 sub-shadow-offset=.75
 sub-pos=102
 sub-border-size=2
 #sub-margin-x=10
 #sub-margin-y=10

#AUDIO PLAYER OSC#
[audio]
#audio-samplerate=192000
msg-level=ao=info
#ao=wasapi                                    # WASAPI audio output (Windows)
cache=yes
#demuxer-max-bytes=100MiB
audio-channels=7.1,5.1,stereo
#audio-device='wasapi/{xxxxxxxx-...}'         # mpv --audio-device=help
no-resume-playback
start=0
volume=100
watch-later-options-remove=start
script-opts=osc-visibility=always
save-position-on-quit=no
#glsl-shaders-clr
scale=lanczos
#glsl-shaders-append="~~/shaders/SSimSuperRes.glsl"
#glsl-shaders-append="~~/shaders/SSimDownscaler.glsl"

[dts]
ao=wasapi                                    # WASAPI audio output (Windows)
audio-channels=7.1,5.1,stereo
#audio-device='wasapi/{xxxxxxxx-...}'        # set to your device (see the global section for how to find it)
audio-exclusive=yes
audio-spdif=ac3,dts,eac3,dts-hd,truehd
#cache=yes
#demuxer-max-bytes=100MiB
no-resume-playback
start=0
volume=100
watch-later-options-remove=start
script-opts=osc-visibility=always
save-position-on-quit=no
#glsl-shaders-clr
scale=lanczos
#glsl-shaders-append="~~/shaders/SSimSuperRes.glsl"
#glsl-shaders-append="~~/shaders/SSimDownscaler.glsl"

[extension.dts]
profile=dts
[extension.mp3]
profile=audio
[extension.m4a]
profile=audio
[extension.wav]
profile=audio
[extension.flac]
profile=audio
[extension.ogg]
profile=audio
[extension.opus]
profile=audio
[extension.cue]
profile=audio
[extension.m3a]
profile=audio
[extension.mkv]
profile=mkv

[mkv]
cache=yes
#demuxer-max-bytes=100MiB

[low-res video]
profile-desc=cond:(get('height', math.huge) < 720) and (get('estimated-frame-count', math.huge) > 2)
scale=lanczos
#glsl-shaders-append="~~/shaders/adaptive-sharpen.glsl"
deband-grain=60

[720p video]
profile-desc=cond:(get('height', math.huge) < 721) and (get('height', math.huge) > 719) and (get('estimated-frame-count', math.huge) > 2)
scale=lanczos
#glsl-shaders-append="~~/shaders/SSimSuperRes.glsl"
deband-grain=100

[hi-res video]
profile-desc=cond:get('height', math.huge) > 720 and (get('estimated-frame-count', math.huge) > 2) or (get('estimated-frame-count', math.huge) ~= 0)
scale=lanczos
#glsl-shaders-clr
#glsl-shaders="~~/shaders/FSR.glsl"
#glsl-shaders-append="~~/shaders/adaptive-sharpen8k.glsl"
#glsl-shaders-append="~~/shaders/SSimSuperRes.glsl"
#glsl-shaders-append="~~/shaders/SSimDownscaler.glsl"

#image shaders#

[hi-res-image]
profile-desc=cond:(get('current-window-scale', math.huge) <= 1) and (get('estimated-frame-count', math.huge) == 1 or get('estimated-frame-count', math.huge) == 0)
dscale=lanczos
dscale-blur=0.8
#glsl-shaders-clr
#glsl-shaders="~~/shaders/SSimDownscaler.glsl"
#glsl-shaders="~~/shaders/KrigBilateral.glsl"

[low-res-image]
profile-desc=cond:(get('current-window-scale', math.huge) > 1) and (get('estimated-frame-count', math.huge) == 1 or get('estimated-frame-count', math.huge) == 0)
scale=lanczos
fbo-format=rgba16hf
#glsl-shaders-clr
#glsl-shaders="~~/shaders/SSimSuperRes.glsl"
#glsl-shaders-append="~~/shaders/KrigBilateral.glsl"
#glsl-shaders-append="~~/shaders/adaptive-sharpen4k.glsl"
#glsl-shaders-append="~~/shaders/SSimDownscaler.glsl"

[protocol.file]
network-timeout=0
force-window=yes
cache=yes
cache-pause=yes
force-seekable=yes
demuxer-max-bytes=1024MiB
#demuxer-readahead-secs=30


[protocol-network]
network-timeout=5
hls-bitrate=max
http-segmented-connections=8
http-segmented-chunk-size=5MiB
cache=yes
cache-pause=yes
# Next-file prefetch (custom patch): start demuxer-prefetching the next playlist
# entry as soon as the current file plays smoothly (not just near EOF), held
# cheap while it prefetches — the next file's demuxer cache is capped at
# prefetch-demuxer-max-bytes and its segmented-http download runs with
# only http-segmented-prefetch-connections workers, so it never steals bandwidth from
# what's playing. On promotion to the current file the cap lifts to
# demuxer-max-bytes and parallelism ramps to the full http-segmented-connections, keeping
# the already-buffered data (no reopen). Prefetch honours
# demuxer-cache-unselected-audio/subs automatically.
prefetch-playlist=immediate
prefetch-demuxer-max-bytes=1024MiB   # 0 = 256MiB default
http-segmented-prefetch-connections=2                   # workers during prefetch; ramps to http-segmented-connections
force-window=immediate

[protocol.http]
profile=protocol-network

[protocol.https]
profile=protocol-network

[image]
profile-cond=image
icc-profile-auto=no
mute=yes
osc=no                               # the osc is mostly useful for videos
sub-auto=no                          # don't try to autoload subtitles or audio files
audio-file-auto=no                   # get rid of the useless V: 00:00:00 / 00:00:00 line
image-display-duration=inf           # don't slideshow by default
loop-file=inf                        # loop files in case of webms or gifs
loop-playlist=inf                    # and loop the whole playlist
window-dragging=no                   # you need this if you plan to use drag-to-pan or pan-follows-cursor with MOUSE_LEFT
deband=no
#background=0.1 # dark grey background instead of pure black

[extension.png]
video-aspect-override=no    
[extension.jpg]
video-aspect-override=no
[extension.jpeg]
profile=extension.jpg
[silent]
msg-level=all=no
